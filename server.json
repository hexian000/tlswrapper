{
  "api_listen": "127.0.0.1:9082",
  "mux_listen": "127.0.0.1:8443",
  "listen": "127.0.0.1:5203",
  "connect": "127.0.0.1:5201",
  "tls": {
    "cert": "@server-cert.pem",
    "key": "@server-key.pem",
    "authcerts": [
      "@client-cert.pem"
    ]
  },
  "timeout": 60,
  "keepalive": 25,
  "loglevel": 8,
  "max_streams": 1000,
  "max_startups": "10:30:60"
}