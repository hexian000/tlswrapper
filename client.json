{
  "mux_connect": "127.0.0.1:8443",
  "listen": "127.0.0.1:5202",
  "connect": "127.0.0.1:5201",
  "tls": {
    "cert": "@client-cert.pem",
    "key": "@client-key.pem",
    "authcerts": [
      "@server-cert.pem"
    ]
  },
  "-mux": {
    "stream_window": 16777216,
    "session_window": 16777216
  },
  "timeout": 60,
  "idle_timeout": 0,
  "keepalive": 25,
  "loglevel": 5
}