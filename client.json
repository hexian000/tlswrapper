{
  "type": "application/x-tlswrapper-config; version=4",
  "tls": {
    "cert": "@client-cert.pem",
    "key": "@client-key.pem",
    "authcerts": [
      "@server-cert.pem"
    ]
  },
  "service": {
    "id": "client",
    "peers": {
      "server": "example.com:38000"
    },
    "listen": {
      "server": "127.0.0.1:8080"
    }
  }
}